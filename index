<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPACE — Your Habit Universe</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #020208;
    --surface: #0a0a16;
    --surface2: #111120;
    --surface3: #181828;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f2f2ff;
    --text-dim: rgba(242,242,255,0.52);
    --text-dimmer: rgba(242,242,255,0.28);
    --accent: #7b6cf6;
    --accent2: #e85cff;
    --accent3: #38ffd0;
    --gold: #f5c842;
    --radius: 22px;
    --nav-h: 70px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: 'Space Grotesk', sans-serif; overflow-x: hidden; }
  body::after { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9999; opacity: 0.45; }
  h1,h2,h3,h4 { font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.03em; }
  .brand { font-family: 'Space Grotesk', sans-serif; font-weight: 700; letter-spacing: -0.05em; }
  .mono { font-family: 'Space Mono', monospace; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 800; height: var(--nav-h); display: flex; align-items: center; justify-content: space-between; padding: 0 52px; background: rgba(2,2,8,0.78); backdrop-filter: blur(28px) saturate(1.6); border-bottom: 1px solid var(--border); transition: background 0.3s; }
  .nav-logo { font-family: 'Space Grotesk', sans-serif; font-size: 23px; font-weight: 700; letter-spacing: -0.05em; text-decoration: none; background: linear-gradient(120deg,#fff 0%,var(--accent) 55%,var(--accent2) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .nav-links { display: flex; gap: 38px; list-style: none; }
  .nav-links a { font-size: 14px; font-weight: 500; color: var(--text-dim); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--text); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .btn-outline { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-dim); background: transparent; border: 1px solid var(--border2); padding: 9px 20px; border-radius: 50px; cursor: pointer; text-decoration: none; transition: all 0.2s; }
  .btn-outline:hover { color: var(--text); border-color: rgba(255,255,255,0.28); }
  .btn-gplay { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; background: #fff; color: #0a0a16; padding: 10px 22px; border-radius: 50px; text-decoration: none; border: none; cursor: pointer; transition: all 0.22s; box-shadow: 0 0 28px rgba(255,255,255,0.12); }
  .btn-gplay:hover { transform: translateY(-1px); box-shadow: 0 6px 36px rgba(255,255,255,0.2); }

  /* HERO */
  .hero { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 130px 24px 60px; position: relative; overflow: hidden; }
  .orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; }
  .orb1 { width: 700px; height: 500px; top: -100px; left: 50%; transform: translateX(-50%); background: radial-gradient(ellipse, rgba(123,108,246,0.18) 0%, transparent 70%); }
  .orb2 { width: 500px; height: 500px; bottom: -80px; left: -100px; background: radial-gradient(circle, rgba(56,255,208,0.07) 0%, transparent 70%); }
  .orb3 { width: 400px; height: 400px; bottom: 0; right: -60px; background: radial-gradient(circle, rgba(232,92,255,0.1) 0%, transparent 70%); }
  .hero-pill { display: inline-flex; align-items: center; gap: 8px; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent3); background: rgba(56,255,208,0.07); border: 1px solid rgba(56,255,208,0.2); padding: 6px 16px; border-radius: 50px; margin-bottom: 36px; animation: fadeUp 0.7s ease both; }
  .hero-pill .blink { width: 5px; height: 5px; border-radius: 50%; background: var(--accent3); animation: blink 2s ease infinite; }
  .hero-h1 { font-family: 'Space Grotesk', sans-serif; font-size: clamp(58px, 9.5vw, 116px); font-weight: 700; line-height: 0.93; letter-spacing: -0.05em; margin-bottom: 28px; animation: fadeUp 0.7s 0.08s ease both; }
  .hero-h1 .word-space { font-family: 'Space Grotesk', sans-serif; font-weight: 700; display: block; background: linear-gradient(110deg,#fff 0%,var(--accent) 45%,var(--accent2) 80%,var(--accent3) 100%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: shimmer 5s linear infinite; }
  .hero-h1 .word-rest { display: block; color: rgba(242,242,255,0.88); }
  .hero-sub { font-family: 'Space Grotesk', sans-serif; font-size: clamp(16px, 2vw, 19px); font-weight: 400; color: var(--text-dim); line-height: 1.72; max-width: 520px; margin-bottom: 52px; animation: fadeUp 0.7s 0.16s ease both; }
  .hero-sub strong { color: var(--text); font-weight: 600; }
  .hero-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; justify-content: center; animation: fadeUp 0.7s 0.22s ease both; margin-bottom: 20px; }
  .btn-hero-main { display: inline-flex; align-items: center; gap: 10px; font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 700; background: #fff; color: #08080f; padding: 15px 32px; border-radius: 50px; text-decoration: none; border: none; cursor: pointer; transition: all 0.22s; box-shadow: 0 0 40px rgba(255,255,255,0.14); }
  .btn-hero-main:hover { transform: translateY(-2px); box-shadow: 0 8px 48px rgba(255,255,255,0.22); }
  .btn-hero-ghost { display: inline-flex; align-items: center; gap: 8px; font-family: 'Space Grotesk', sans-serif; font-size: 15px; font-weight: 600; color: var(--text-dim); background: transparent; border: 1px solid var(--border2); padding: 15px 32px; border-radius: 50px; text-decoration: none; cursor: pointer; transition: all 0.2s; }
  .btn-hero-ghost:hover { color: var(--text); border-color: rgba(255,255,255,0.25); }
  .platform-note { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--text-dimmer); letter-spacing: 0.08em; animation: fadeUp 0.7s 0.28s ease both; margin-bottom: 72px; display: flex; align-items: center; gap: 8px; }
  .hero-stats { display: flex; align-items: center; animation: fadeUp 0.7s 0.34s ease both; }
  .hstat { text-align: center; padding: 0 40px; }
  .hstat:not(:last-child) { border-right: 1px solid var(--border); }
  .hstat-num { font-family: 'Space Grotesk', sans-serif; font-size: 34px; font-weight: 700; letter-spacing: -0.04em; background: linear-gradient(135deg,var(--text),var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 4px; }
  .hstat-label { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--text-dimmer); letter-spacing: 0.1em; text-transform: uppercase; }

  /* PHONE SHOWCASE */
  .showcase { padding: 0 24px 140px; display: flex; justify-content: center; position: relative; overflow: visible; }
  .showcase-wrap { position: relative; width: 300px; }
  .phone { width: 300px; height: 618px; background: linear-gradient(170deg,#181830 0%,#0c0c1e 100%); border-radius: 48px; border: 1.5px solid rgba(255,255,255,0.1); box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 50px 140px rgba(0,0,0,0.85), 0 0 100px rgba(123,108,246,0.12), inset 0 1px 0 rgba(255,255,255,0.08); overflow: hidden; position: relative; animation: floatPhone 7s ease-in-out infinite; }
  .notch { position: absolute; top: 14px; left: 50%; transform: translateX(-50%); width: 110px; height: 30px; background: #000; border-radius: 20px; z-index: 10; }
  .screen { padding: 58px 18px 20px; height: 100%; display: flex; flex-direction: column; gap: 10px; }
  .s-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px; }
  .s-logo { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: -0.05em; background: linear-gradient(120deg,#fff,var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .s-av { width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg,var(--accent),var(--accent2)); }
  .s-tabs { display: flex; gap: 4px; background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 10px; padding: 4px; margin-bottom: 6px; }
  .s-tab { flex: 1; text-align: center; font-size: 9px; font-weight: 600; padding: 5px 0; border-radius: 7px; color: var(--text-dimmer); }
  .s-tab.active { background: var(--accent); color: #fff; }
  .s-streak { display: flex; align-items: center; gap: 10px; background: linear-gradient(120deg,rgba(123,108,246,0.18),rgba(232,92,255,0.1)); border: 1px solid rgba(123,108,246,0.22); border-radius: 14px; padding: 12px 14px; }
  .s-streak-icon { font-size: 22px; }
  .s-streak-text { flex: 1; }
  .s-streak-label { font-size: 9px; color: var(--text-dimmer); font-weight: 600; letter-spacing: 0.06em; margin-bottom: 1px; }
  .s-streak-val { font-family: 'Space Grotesk', sans-serif; font-size: 18px; font-weight: 700; color: #fff; letter-spacing: -0.03em; }
  .s-streak-badge { font-size: 9px; font-weight: 700; background: rgba(56,255,208,0.15); color: var(--accent3); border: 1px solid rgba(56,255,208,0.25); padding: 3px 8px; border-radius: 20px; }
  .s-habits { display: flex; flex-direction: column; gap: 6px; }
  .s-habit { display: flex; align-items: center; gap: 9px; background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.055); border-radius: 11px; padding: 9px 11px; }
  .s-hcheck { width: 19px; height: 19px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; flex-shrink: 0; }
  .s-hcheck.done { background: var(--accent3); color: #000; font-weight: 700; }
  .s-hcheck.todo { border: 1.5px solid rgba(255,255,255,0.18); }
  .s-hname { font-size: 10px; font-weight: 500; flex: 1; }
  .s-hstreak { font-size: 9px; color: var(--text-dimmer); }
  .s-couple { display: flex; align-items: center; gap: 8px; background: rgba(232,92,255,0.08); border: 1px solid rgba(232,92,255,0.18); border-radius: 50px; padding: 7px 14px; margin-top: 2px; }
  .s-cavs { display: flex; }
  .s-cav { width: 20px; height: 20px; border-radius: 50%; border: 1.5px solid var(--bg); margin-right: -5px; }
  .cav1 { background: linear-gradient(135deg,var(--accent),var(--accent2)); }
  .cav2 { background: linear-gradient(135deg,var(--accent3),var(--accent)); }
  .s-ctext { font-size: 9px; color: rgba(232,92,255,0.9); font-weight: 600; margin-left: 8px; }
  .fc { position: absolute; background: rgba(10,10,22,0.92); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.09); border-radius: 16px; padding: 13px 18px; white-space: nowrap; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
  .fc-l { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--text-dimmer); letter-spacing: 0.08em; margin-bottom: 4px; text-transform: uppercase; }
  .fc-v { font-family: 'Space Grotesk', sans-serif; font-size: 16px; font-weight: 700; color: var(--text); }
  .fc-v .em { color: var(--accent3); }
  .fc-v .emp { color: var(--accent2); }
  .fc1 { left: -155px; top: 90px; animation: floatPhone 5s 0.4s ease-in-out infinite; }
  .fc2 { right: -148px; top: 200px; animation: floatPhone 5.5s 0.9s ease-in-out infinite; }
  .fc3 { left: -140px; bottom: 160px; animation: floatPhone 6s 1.4s ease-in-out infinite; }

  /* SECTION SHARED */
  .section-tag { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
  .section-tag::before { content: ''; width: 22px; height: 1px; background: var(--accent); display: block; }
  .section-h { font-family: 'Space Grotesk', sans-serif; font-size: clamp(36px, 5.5vw, 68px); font-weight: 700; line-height: 1.03; letter-spacing: -0.04em; margin-bottom: 20px; }
  .section-p { font-family: 'Space Grotesk', sans-serif; font-size: 17px; line-height: 1.72; color: var(--text-dim); }
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.85s ease, transform 0.85s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* MODES */
  .modes { padding: 130px 24px; background: var(--surface); position: relative; overflow: hidden; }
  .modes::before { content: ''; position: absolute; top: -200px; right: -200px; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle,rgba(123,108,246,0.06) 0%,transparent 70%); pointer-events: none; }
  .modes-header { text-align: center; max-width: 620px; margin: 0 auto 80px; }
  .modes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1080px; margin: 0 auto; }
  .mode-card { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 40px 32px; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
  .mode-card:hover { border-color: rgba(123,108,246,0.28); transform: translateY(-3px); }
  .mode-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg,transparent,rgba(255,255,255,0.1),transparent); }
  .mode-card.featured { border-color: rgba(123,108,246,0.3); background: linear-gradient(160deg,rgba(123,108,246,0.07) 0%,var(--surface2) 70%); }
  .mode-icon { width: 52px; height: 52px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 24px; }
  .mi-p { background: rgba(123,108,246,0.14); }
  .mi-c { background: rgba(232,92,255,0.12); }
  .mi-g { background: rgba(56,255,208,0.1); }
  .mode-tag { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dimmer); margin-bottom: 8px; }
  .mode-name { font-family: 'Space Grotesk', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 14px; }
  .mode-desc { font-family: 'Space Grotesk', sans-serif; font-size: 14px; line-height: 1.72; color: var(--text-dim); margin-bottom: 24px; }
  .mode-features { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .mode-features li { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; color: var(--text-dim); }
  .mf-dot { width: 16px; height: 16px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 8px; flex-shrink: 0; margin-top: 1px; }
  .mf-dot.a { background: rgba(123,108,246,0.15); color: var(--accent); }
  .mf-dot.b { background: rgba(232,92,255,0.12); color: var(--accent2); }
  .mf-dot.c { background: rgba(56,255,208,0.1); color: var(--accent3); }
  .mode-badge { display: inline-block; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 12px; border-radius: 50px; margin-top: 24px; }
  .mb-free { background: rgba(56,255,208,0.1); color: var(--accent3); border: 1px solid rgba(56,255,208,0.2); }
  .mb-pro { background: rgba(123,108,246,0.12); color: var(--accent); border: 1px solid rgba(123,108,246,0.25); }

  /* DISCOVER */
  .discover { padding: 130px 24px; max-width: 1100px; margin: 0 auto; }
  .discover-inner { display: grid; grid-template-columns: 1fr 1.1fr; gap: 80px; align-items: center; }
  .disc-card { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; margin-bottom: 16px; }
  .disc-card-title { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-dimmer); margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }
  .disc-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent3); animation: blink 2s infinite; }
  .disc-row { display: flex; align-items: center; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--border); }
  .disc-row:last-child { border-bottom: none; padding-bottom: 0; }
  .disc-av { width: 42px; height: 42px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .da1 { background: rgba(123,108,246,0.18); }
  .da2 { background: rgba(56,255,208,0.12); }
  .da3 { background: rgba(232,92,255,0.12); }
  .da4 { background: rgba(245,200,66,0.1); }
  .disc-info { flex: 1; }
  .disc-name { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
  .disc-meta { font-size: 10px; color: var(--text-dimmer); font-family: 'Space Mono', monospace; }
  .disc-join { font-family: 'Space Grotesk', sans-serif; font-size: 11px; font-weight: 700; color: var(--accent); background: rgba(123,108,246,0.1); border: 1px solid rgba(123,108,246,0.22); padding: 5px 14px; border-radius: 50px; cursor: pointer; transition: all 0.2s; }
  .disc-join:hover { background: rgba(123,108,246,0.2); }
  .trend-card { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 24px 28px; }
  .trend-title { font-family: 'Space Grotesk', sans-serif; font-size: 13px; font-weight: 600; color: var(--text-dimmer); margin-bottom: 14px; }
  .trend-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { font-size: 12px; font-weight: 500; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); padding: 6px 14px; border-radius: 50px; color: var(--text-dim); transition: all 0.2s; cursor: pointer; }
  .chip:hover { border-color: rgba(123,108,246,0.35); color: var(--text); }
  .chip.hot { border-color: rgba(232,92,255,0.3); color: rgba(232,92,255,0.9); background: rgba(232,92,255,0.07); }

  /* FEATURES BENTO */
  .features { padding: 130px 24px; background: var(--surface); }
  .features-header { text-align: center; max-width: 600px; margin: 0 auto 80px; }
  .bento { display: grid; grid-template-columns: repeat(12, 1fr); gap: 16px; max-width: 1080px; margin: 0 auto; }
  .bc { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 36px; position: relative; overflow: hidden; transition: border-color 0.3s, transform 0.3s; }
  .bc:hover { border-color: rgba(123,108,246,0.3); transform: translateY(-2px); }
  .bc::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 0% 0%,rgba(123,108,246,0.06) 0%,transparent 55%); pointer-events: none; }
  .bc1 { grid-column: span 7; }
  .bc2 { grid-column: span 5; }
  .bc3 { grid-column: span 4; }
  .bc4 { grid-column: span 4; }
  .bc5 { grid-column: span 4; }
  .bc-icon { width: 48px; height: 48px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 22px; }
  .bi-v { background: rgba(123,108,246,0.14); }
  .bi-p { background: rgba(232,92,255,0.12); }
  .bi-t { background: rgba(56,255,208,0.1); }
  .bi-g { background: rgba(245,200,66,0.1); }
  .bc-title { font-family: 'Space Grotesk', sans-serif; font-size: 21px; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 10px; }
  .bc-desc { font-family: 'Space Grotesk', sans-serif; font-size: 14px; line-height: 1.7; color: var(--text-dim); }

  /* PRICING */
  .pricing { padding: 130px 24px; background: var(--bg); }
  .pricing-header { text-align: center; max-width: 560px; margin: 0 auto 80px; }
  .pricing-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 840px; margin: 0 auto; }
  .pcard { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 44px; position: relative; overflow: hidden; transition: all 0.3s; }
  .pcard.pro { border-color: rgba(123,108,246,0.35); background: linear-gradient(160deg,rgba(123,108,246,0.07) 0%,var(--surface2) 60%); }
  .pcard.pro::before { content: ''; position: absolute; inset: -1px; border-radius: var(--radius); background: linear-gradient(135deg,rgba(123,108,246,0.45),rgba(232,92,255,0.25),transparent 60%); z-index: -1; }
  .pcard-badge { display: inline-block; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; background: linear-gradient(135deg,var(--accent),var(--accent2)); color: #fff; padding: 4px 14px; border-radius: 50px; margin-bottom: 28px; }
  .pcard-name { font-family: 'Space Grotesk', sans-serif; font-size: 30px; font-weight: 700; letter-spacing: -0.04em; margin-bottom: 10px; }
  .pcard-price { font-family: 'Space Grotesk', sans-serif; font-size: 54px; font-weight: 700; letter-spacing: -0.05em; line-height: 1; margin-bottom: 4px; }
  .pcard-price sup { font-size: 24px; vertical-align: super; }
  .pcard-price .pnote { font-size: 16px; font-weight: 400; color: var(--text-dim); }
